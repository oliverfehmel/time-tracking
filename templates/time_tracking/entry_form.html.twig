{% extends 'base.html.twig' %}

{% block title %}{{ title|trans }}{% endblock %}

{% block body %}
    <div class="tt-page">
        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-3">
            <div>
                <h1 class="h3 mb-1">{{ title|trans }}</h1>
                <p class="text-muted mb-0">{{ day|date('d.m.Y') }}</p>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-sm btn-outline-secondary"
                   href="{{ path('_time_day', {date: day|date('Y-m-d')}) }}">
                    <i class="fa-solid fa-arrow-left me-1"></i>
                    {{ 'general.back'|trans }}
                </a>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                {{ form_start(form, {attr: {class: 'row g-3'}}) }}

                <div class="col-12 col-md-6">
                    {{ form_row(form.startTime, {
                        row_attr: { class: 'mb-0' }
                    }) }}
                </div>

                <div class="col-12 col-md-6">
                    {{ form_row(form.endTime, {
                        row_attr: { class: 'mb-0' }
                    }) }}
                    <small class="text-muted">{{ 'time_tracking.end_time_help'|trans }}</small>
                </div>

                <div class="col-12 d-flex justify-content-end gap-2 mt-2">
                    <button class="btn btn-primary" type="submit">
                        <i class="fa-regular fa-floppy-disk me-1"></i>
                        {{ 'general.save'|trans }}
                    </button>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
