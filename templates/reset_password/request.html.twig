{% extends 'base.html.twig' %}

{% block title %}{{ 'password_reset.request.title'|trans }}{% endblock %}

{% block body %}
    <div class="page-center">
        <div class="card shadow-sm auth-card">
            <div class="card-body">
                <div class="mb-3">
                    <h1 class="h3 mb-1">{{ 'password_reset.request.title'|trans }}</h1>
                    <p class="text-muted mb-0">{{ 'password_reset.request.subtitle'|trans }}</p>
                </div>

                {% for flash_error in app.flashes('reset_password_error') %}
                    <div class="alert alert-danger" role="alert">
                        <i class="fa-solid fa-triangle-exclamation me-1"></i>
                        {{ flash_error }}
                    </div>
                {% endfor %}

                {{ form_start(requestForm, { attr: { class: 'd-grid gap-3' } }) }}

                {{ form_row(requestForm.email, {
                    attr: {
                        placeholder: 'name@time-tracking.de',
                        autocomplete: 'email'
                    }
                }) }}

                <div class="d-flex justify-content-between align-items-center gap-2 mt-1">
                    <a class="small text-decoration-none" href="{{ path('_login') }}">
                        <i class="fa-solid fa-arrow-left me-1"></i>
                        {{ 'general.back'|trans }} zum {{ 'auth.login'|trans }}
                    </a>

                    <button class="btn btn-primary" type="submit">
                        <i class="fa-regular fa-paper-plane me-1"></i>
                        {{ 'password_reset.request.send_email'|trans }}
                    </button>
                </div>

                {{ form_end(requestForm) }}
            </div>
        </div>
    </div>
{% endblock %}
