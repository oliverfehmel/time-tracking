{# templates/profile/index.html.twig (oder templates/user/profile.html.twig) #}
{% extends 'base.html.twig' %}

{% block title %}{{ 'profile.title'|trans }}{% endblock %}

{% block body %}
    <div class="tt-page">
        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-3">
            <div>
                <h1 class="h3 mb-1">{{ 'profile.title'|trans }}</h1>
                <p class="text-muted mb-0">{{ 'profile.subtitle'|trans }}</p>
            </div>
        </div>

        {{ form_start(form, { attr: { novalidate: 'novalidate', class: 'row g-3' } }) }}

        {# {{ 'profile.master_data'|trans }} #}
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <div class="fw-semibold">{{ 'profile.master_data'|trans }}</div>
                    <div class="text-muted small">{{ 'profile.master_data_subtitle'|trans }}</div>
                </div>

                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            {{ form_row(form.name) }}
                        </div>

                        <div class="col-12 col-md-6">
                            {{ form_row(form.email) }}
                        </div>

                        <div class="col-12 col-md-6">
                            {{ form_row(form.dailyWorkMinutes) }}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <div class="fw-semibold">{{ 'profile.change_password'|trans }}</div>
                    <div class="text-muted small">{{ 'profile.change_password_subtitle'|trans }}</div>
                </div>

                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            {{ form_row(form.plainPassword.first) }}
                        </div>

                        <div class="col-12 col-md-6">
                            {{ form_row(form.plainPassword.second) }}
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white d-flex justify-content-end gap-2">
                    <button class="btn btn-primary" type="submit">
                        <i class="fa-regular fa-floppy-disk me-1"></i>
                        {{ 'general.save'|trans }}
                    </button>
                </div>
            </div>
        </div>

        {{ form_end(form) }}
    </div>
{% endblock %}
