{% extends 'base.html.twig' %}

{% block title %}Abwesenheitsübersicht – {{ ('month.' ~ monthStart|date('F'))|trans }} {{ monthStart|date('Y') }}{% endblock %}

{% block body %}
    {% set dayPercent = 100 / daysInMonth %}
    {% set todayYm = 'now'|date('Y-m') %}
    {% set viewYm  = monthStart|date('Y-m') %}
    {% set todayDayInView = null %}
    {% if todayYm == viewYm %}
        {% set todayDayInView = 'now'|date('j') + 0 %}
    {% endif %}

    <div class="container-fluid py-3"
         data-controller="absence-overview"
         data-absence-overview-days-in-month-value="{{ daysInMonth }}">

        <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between mb-3">
            <div>
                <h1 class="h4 mb-1">Abwesenheitsübersicht</h1>
                <div class="text-muted">Monat: <strong>{{ ('month.' ~ monthStart|date('F'))|trans }} {{ monthStart|date('Y') }}</strong></div>
            </div>

            <div class="d-flex flex-wrap gap-2 align-items-center">
                <a class="btn btn-outline-secondary btn-sm"
                   href="{{ path('_absences_overview', { month: prevMonth|date('Y-m') }) }}">
                    ← {{ ('month.' ~ prevMonth|date('M'))|trans }} {{ prevMonth|date('Y') }}
                </a>

                <a class="btn btn-outline-secondary btn-sm"
                   href="{{ path('_absences_overview', { month: 'now'|date('Y-m') }) }}">
                    Heute
                </a>

                <a class="btn btn-outline-secondary btn-sm"
                   href="{{ path('_absences_overview', { month: nextMonth|date('Y-m') }) }}">
                    {{ ('month.' ~ nextMonth|date('M'))|trans }} {{ nextMonth|date('Y') }} →
                </a>

                <form class="d-flex gap-2 align-items-center" method="get" action="{{ path('_absences_overview') }}">
                    <input type="month" class="form-control form-control-sm" name="month" value="{{ monthStart|date('Y-m') }}">
                    <button class="btn btn-primary btn-sm" type="submit">Anzeigen</button>
                </form>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-0 absence-overview__card-body">

                <div class="absence-grid">
                    <div class="absence-grid__cell absence-grid__cell--sticky absence-grid__cell--header-left">
                        <div class="px-3 py-2 fw-semibold">Mitarbeiter</div>
                    </div>

                    <div class="absence-grid__cell absence-grid__cell--header-days">
                        <div class="days-row" style="grid-template-columns: repeat({{ daysInMonth }}, 1fr);">
                            {% for d in days %}
                                {% set isWeekend = d.dow in [6,7] %}
                                {% set isToday = (todayDayInView is not null and d.day == todayDayInView) %}
                                <div class="day-cell {{ isWeekend ? 'day-cell--weekend' : '' }} {{ isToday ? 'day-cell--today' : '' }}">
                                    <div class="day-num">{{ d.day }}</div>
                                    <div class="day-dow">{{ ['Mo','Di','Mi','Do','Fr','Sa','So'][d.dow-1] }}</div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>

                    {% for user in users %}
                        {% set uid = user.id %}

                        <div class="absence-grid__cell absence-grid__cell--sticky absence-grid__cell--user">
                            <div class="px-3 py-2 text-truncate">
                                <div class="fw-semibold">
                                    {{ user.name ?? ('User #' ~ uid) }}
                                </div>
                            </div>
                        </div>

                        <div class="absence-grid__cell absence-grid__cell--timeline">
                            <div class="timeline"
                                 style="width: calc({{ daysInMonth }} * var(--day-width));">

                                <div class="timeline__grid" style="grid-template-columns: repeat({{ daysInMonth }}, 1fr);">
                                    {% if todayDayInView is not null %}
                                        <div class="timeline__today-line"
                                             style="left: calc((({{ todayDayInView - 0.5 }}) * {{ dayPercent }}) * 1%);"></div>
                                    {% endif %}
                                    {% for d in days %}
                                        {% set isWeekend = d.dow in [6,7] %}
                                        {% set isToday = (todayDayInView is not null and d.day == todayDayInView) %}
                                        <div class="timeline__grid-day
                                                    {{ isWeekend ? 'timeline__grid-day--weekend' : '' }}
                                                    {{ isToday ? 'timeline__grid-day--today' : '' }}"></div>
                                    {% endfor %}
                                </div>

                                {% set holidayDays = holidayDaysByUser[uid] ?? {} %}
                                {% for d in days %}
                                    {% if holidayDays[d.day] is defined %}
                                        {% set names = holidayDays[d.day] %}
                                        <div class="holiday-dot"
                                             style="left: calc((({{ d.day - 0.5 }}) * {{ dayPercent }}) * 1%);"
                                             title="Feiertag: {{ names|join(' / ') }}">
                                        </div>
                                    {% endif %}
                                {% endfor %}

                                {% for bar in (barsByUser[uid] ?? []) %}
                                    {% set cls = typeClassMap[bar.typeKey] ?? 'bg-dark' %}
                                    {% set isPending = bar.status == statusPending %}

                                    <div class="absence-bar {{ cls }} {{ isPending ? 'absence-bar--pending' : '' }}"
                                         style="
                                             left: calc(({{ bar.startDay - 1 }} * {{ dayPercent }}) * 1%);
                                             width: calc({{ bar.days }} * {{ dayPercent }}%);
                                         "
                                         data-action="mouseover->absence-overview#showTooltip mousemove->absence-overview#moveTooltip mouseout->absence-overview#hideTooltip"
                                         data-absence-tooltip="
                       <strong>{{ bar.typeName }}</strong><br>
                       {{ monthStart|date('Y') }}-{{ monthStart|date('m') }}-{{ '%02d'|format(bar.startDay) }}
                       bis
                       {{ monthStart|date('Y') }}-{{ monthStart|date('m') }}-{{ '%02d'|format(bar.endDay) }}<br>
                       Status: {{ bar.status }}
                       {% if bar.comment %}<br>Kommentar: {{ bar.comment|e('html_attr') }}{% endif %}
                     ">
                  <span class="absence-bar__label">
                    {{ bar.typeName }}{% if isPending %} (pending){% endif %}
                  </span>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endfor %}
                </div>

            </div>
        </div>

        <div class="mt-3 small text-muted d-flex flex-wrap gap-3 align-items-center">
            <span class="fw-semibold">Legende:</span>
            {% for key, cls in typeClassMap %}
                <span class="legend-item">
                    <span class="legend-dot {{ cls }}"></span>
                    <span>{{ typeLabelMap[key] ?? key }}</span>
                </span>
            {% endfor %}
            <span class="legend-item"><span class="legend-dot legend-dot--holiday"></span> <span>Feiertag</span></span>
            <span class="legend-item"><span class="legend-dot legend-dot--pending"></span> <span>Pending</span></span>
        </div>

        <div data-absence-overview-target="tooltip" class="abs-tooltip" hidden></div>
    </div>
{% endblock %}
