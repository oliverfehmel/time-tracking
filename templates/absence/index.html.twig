{% extends 'base.html.twig' %}

{% block title %}{{ 'absence.title'|trans({'year': year}) }}{% endblock %}

{% block body %}
    <div class="tt-page">
        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-3">
            <div>
                <h1 class="h3 mb-1">{{ 'absence.title'|trans({'year': year}) }}</h1>
                <p class="text-muted mb-0">{{ 'absence.subtitle'|trans }}</p>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-sm btn-primary" href="{{ path('_absence_new', {year: year}) }}">
                    <i class="fa-solid fa-plus me-1"></i>
                    {{ 'absence.request.title'|trans }}
                </a>
            </div>
        </div>

        <section class="card shadow-sm mb-3">
            <div class="card-header bg-white">
                <div class="fw-semibold">{{ 'absence.contingents.title'|trans }}</div>
                <div class="text-muted small">{{ 'absence.contingents.subtitle'|trans }}</div>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                        <tr>
                            <th>{{ 'absence.absence_type'|trans }}</th>
                            <th>{{ 'absence.contingent'|trans }}</th>
                            <th>{{ 'absence.used'|trans }}</th>
                            <th>{{ 'absence.pending'|trans }}</th>
                            <th>{{ 'absence.available'|trans }}</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for row in quota %}
                            <tr>
                                <td class="fw-semibold">{{ row.type.name }}</td>
                                <td>
                                    {% if row.quotaDays is null %}
                                        {% if row.type.requiresQuota %}
                                            <span class="text-muted">{{ 'absence.unlimited'|trans }}</span>
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    {% else %}
                                        {{ row.quotaDays }}
                                    {% endif %}
                                </td>
                                <td>{{ row.usedApprovedDays }}</td>
                                <td>{{ row.usedPendingDays }}</td>
                                <td>
                                    {% if row.remainingDays is null %}
                                        {% if row.type.requiresQuota %}
                                            <span class="text-muted">{{ 'absence.unlimited'|trans }}</span>
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    {% else %}
                                        {{ row.remainingDays }}
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section class="card shadow-sm">
            <div class="card-header bg-white">
                <div class="fw-semibold">{{ 'absence.my_absences'|trans }}</div>
                <div class="text-muted small">{{ 'absence.absences_for_year'|trans({'year': year}) }}</div>
            </div>

            <div class="card-body p-0">
                {% if requests is empty %}
                    <p class="text-muted mb-0">{{ 'absence.no_absences'|trans }}</p>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                            <tr>
                                <th>{{ 'absence.absence_type'|trans }}</th>
                                <th>{{ 'absence.from'|trans }}</th>
                                <th>{{ 'absence.to'|trans }}</th>
                                <th>{{ 'absence.days'|trans }}</th>
                                <th>{{ 'absence.status'|trans }}</th>
                                <th class="text-end"></th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for row in requests %}
                                {% set a = row.entity %}

                                {% set statusBadge =
                                    a.status == 'approved' ? 'text-bg-success' :
                                    (a.status == 'pending' ? 'text-bg-warning' :
                                    (a.status == 'rejected' ? 'text-bg-danger' :
                                    (a.status == 'cancelled' ? 'text-bg-secondary' : 'text-bg-light')))
                                %}

                                <tr>
                                    <td class="fw-semibold">{{ a.type.name }}</td>
                                    <td>{{ a.startDate|date('d.m.Y') }}</td>
                                    <td>{{ a.endDate|date('d.m.Y') }}</td>
                                    <td>{{ row.days }}</td>
                                    <td>
                                        <span class="badge {{ statusBadge }}">
                                            {{ ('general.' ~ a.status)|trans }}
                                        </span>

                                        {% if a.status == 'rejected' and a.rejectReason %}
                                            <div class="text-muted small mt-1">
                                                <i class="fa-regular fa-circle-question me-1"></i>
                                                {{ 'absence.reject_reason'|trans({'reason': a.rejectReason}) }}
                                            </div>
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        {% if a.status in ['pending','approved'] %}
                                            <form method="post"
                                                  action="{{ path('_absence_cancel', {id: a.id}) }}"
                                                  class="m-0"
                                                  onsubmit="return confirm('{{ 'absence.request.confirm_cancel'|trans|e('js') }}');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('cancel_absence_' ~ a.id) }}">
                                                <button class="btn btn-sm btn-outline-danger" type="submit">
                                                    <i class="fa-regular fa-circle-xmark me-1"></i>
                                                    {{ 'absence.cancel'|trans }}
                                                </button>
                                            </form>
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </section>
    </div>
{% endblock %}
