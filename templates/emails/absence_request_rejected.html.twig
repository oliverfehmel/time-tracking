<h2>{{ 'email.absence_rejected.title'|trans }}</h2>

<p>{{ 'email.absence_rejected.greeting'|trans({'user': user.name ?: user.email}) }}</p>

<p>{{ 'email.absence_rejected.intro'|trans }}</p>

<ul>
    <li><strong>{{ 'email.period'|trans }}:</strong> {{ absence.startDate|date('d.m.Y') }} - {{ absence.endDate|date('d.m.Y') }}</li>
    <li><strong>{{ 'general.days'|trans }}:</strong> {{ days }}</li>
    <li><strong>{{ 'general.type'|trans }}:</strong> {{ absence.type.name }}</li>
</ul>

{% if absence.rejectReason %}
    <p>
        <strong>{{ 'email.absence_rejected.reason'|trans }}:</strong><br>
        {{ absence.rejectReason|nl2br }}
    </p>
{% endif %}

<p>
    {{ 'email.your_overview'|trans }}
    <a href="{{ overviewUrl }}">{{ overviewUrl }}</a>
</p>
