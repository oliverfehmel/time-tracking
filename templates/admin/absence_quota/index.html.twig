{% extends 'base.html.twig' %}

{% block title %}{{ 'admin_quota.title'|trans }}{% endblock %}

{% block body %}
    <div class="tt-page">
        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-3">
            <div>
                <h1 class="h3 mb-1">{{ 'admin_quota.title'|trans }}</h1>
                <p class="text-muted mb-0">{{ 'admin_quota.subtitle'|trans }}</p>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-sm btn-primary" href="{{ path('_admin_absence_quota_new') }}">
                    <i class="fa-solid fa-plus me-1"></i>
                    {{ 'admin_quota.create'|trans }}
                </a>
            </div>
        </div>

        <section class="card shadow-sm">
            <div class="card-body p-0">
                {% if quotas is empty %}
                    <div class="p-3 text-muted">
                        {{ 'admin_quota.none'|trans }}
                    </div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                            <tr>
                                <th>{{ 'general.year'|trans }}</th>
                                <th>{{ 'general.user'|trans }}</th>
                                <th>{{ 'general.type'|trans }}</th>
                                <th>{{ 'absence.contingent'|trans }}</th>
                                <th>{{ 'admin_quota.over_limit'|trans }}</th>
                                <th class="text-end"></th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for q in quotas %}
                                <tr>
                                    <td class="fw-semibold">{{ q.year }}</td>
                                    <td>{{ q.user.name }}</td>
                                    <td>{{ q.type.name }}</td>
                                    <td>
                                        {% if q.quotaDays is null %}
                                            <span class="text-muted">{{ 'general.unlimited'|trans }}</span>
                                        {% else %}
                                            {{ q.quotaDays }}
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if q.allowOverLimit is same as(null) %}
                                            <span class="badge text-bg-light text-dark">{{ 'general.by_type'|trans }}</span>
                                        {% elseif q.allowOverLimit %}
                                            <span class="badge text-bg-warning">{{ 'general.allowed'|trans }}</span>
                                        {% else %}
                                            <span class="badge text-bg-secondary">{{ 'general.blocked'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-secondary"
                                           href="{{ path('_admin_absence_quota_edit', {id: q.id}) }}">
                                            <i class="fa-regular fa-pen-to-square me-1"></i>
                                            {{ 'general.edit'|trans }}
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </section>
    </div>
{% endblock %}
