{% extends 'base.html.twig' %}

{% block title %}Kontingente{% endblock %}

{% block body %}
    <div class="tt-page">
        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-3">
            <div>
                <h1 class="h3 mb-1">Kontingente</h1>
                <p class="text-muted mb-0">Kontingente pro User/Typ/Jahr verwalten.</p>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-sm btn-primary" href="{{ path('_admin_absence_quota_new') }}">
                    <i class="fa-solid fa-plus me-1"></i>
                    Kontingent anlegen
                </a>
            </div>
        </div>

        <section class="card shadow-sm">
            <div class="card-body p-0">
                {% if quotas is empty %}
                    <div class="p-3 text-muted">
                        Noch keine Kontingente gepflegt.
                    </div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                            <tr>
                                <th>Jahr</th>
                                <th>User</th>
                                <th>Typ</th>
                                <th>Kontingent</th>
                                <th>Überziehung</th>
                                <th class="text-end"></th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for q in quotas %}
                                <tr>
                                    <td class="fw-semibold">{{ q.year }}</td>
                                    <td>{{ q.user.name }}</td>
                                    <td>{{ q.type.name }}</td>
                                    <td>
                                        {% if q.quotaDays is null %}
                                            <span class="text-muted">unbegrenzt</span>
                                        {% else %}
                                            {{ q.quotaDays }}
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if q.allowOverLimit is same as(null) %}
                                            <span class="badge text-bg-light text-dark">vom Typ</span>
                                        {% elseif q.allowOverLimit %}
                                            <span class="badge text-bg-warning">erlaubt</span>
                                        {% else %}
                                            <span class="badge text-bg-secondary">gesperrt</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-secondary"
                                           href="{{ path('_admin_absence_quota_edit', {id: q.id}) }}">
                                            <i class="fa-regular fa-pen-to-square me-1"></i>
                                            Bearbeiten
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </section>
    </div>
{% endblock %}
