{% extends 'base.html.twig' %}

{% block title %}Feiertag bearbeiten{% endblock %}

{% block body %}
    <div class="tt-page">
        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-3">
            <div>
                <h1 class="h3 mb-1">Feiertag bearbeiten</h1>
                <p class="text-muted mb-0">Bearbeite den Feiertag: {{ holiday.name }}</p>
            </div>

            <a class="btn btn-sm btn-outline-secondary" href="{{ path('_admin_holiday_index') }}">
                <i class="fa-solid fa-arrow-left me-1"></i>
                Zurück
            </a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                {{ form_start(form, { attr: { class: 'row g-3' } }) }}

                <div class="col-12 col-md-6">
                    {{ form_row(form.name) }}
                </div>

                <div class="col-12 col-md-6">
                    {{ form_row(form.date) }}
                </div>

                <div class="col-12">
                    {{ form_row(form.users) }}
                </div>

                <div class="col-12 d-flex justify-content-end gap-2 mt-2">
                    <a class="btn btn-outline-secondary" href="{{ path('_admin_holiday_index') }}">
                        Abbrechen
                    </a>
                    <button class="btn btn-primary" type="submit">
                        <i class="fa-regular fa-floppy-disk me-1"></i>
                        Speichern
                    </button>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
