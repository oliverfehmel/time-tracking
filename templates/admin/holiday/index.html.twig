{% extends 'base.html.twig' %}

{% block title %}{{ 'holiday.title'|trans }}{% endblock %}

{% block body %}
    <div class="tt-page">
        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-3">
            <div>
                <h1 class="h3 mb-1">{{ 'holiday.title'|trans }}</h1>
                <p class="text-muted mb-0">{{ 'holiday.subtitle'|trans }}</p>
            </div>

            <a class="btn btn-sm btn-primary" href="{{ path('_admin_holiday_new') }}">
                <i class="fa-solid fa-plus me-1"></i>
                {{ 'holiday.new'|trans }}
            </a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                        <tr>
                            <th>{{ 'general.name'|trans }}</th>
                            <th>{{ 'holiday.date'|trans }}</th>
                            <th>{{ 'navbar.users'|trans }}</th>
                            <th class="text-end">{{ 'general.actions'|trans }}</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for h in holidays %}
                            <tr>
                                <td class="fw-semibold">{{ h.name }}</td>
                                <td>{{ h.date|date('d.m.Y') }}</td>
                                <td>
                                    {% if h.users|length > 0 %}
                                        <div class="d-flex flex-wrap gap-1">
                                            {% for u in h.users %}
                                                <span class="badge text-bg-secondary">
                                                    {{ u.name is not empty ? u.name : u.email }}
                                                </span>
                                            {% endfor %}
                                        </div>
                                    {% else %}
                                        <span class="text-muted">{{ 'general.none'|trans }}</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2 justify-content-end">
                                        <a class="btn btn-sm btn-outline-secondary"
                                           href="{{ path('_admin_holiday_edit', {id: h.id}) }}">
                                            <i class="fa-regular fa-pen-to-square me-1"></i>
                                            {{ 'general.edit'|trans }}
                                        </a>

                                        <form method="post"
                                              action="{{ path('_admin_holiday_delete', {id: h.id}) }}"
                                              class="m-0 d-inline"
                                              onsubmit="return confirm('{{ 'holiday.confirm_delete'|trans|e('js') }}');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_holiday_' ~ h.id) }}">
                                            <button class="btn btn-sm btn-outline-danger" type="submit">
                                                <i class="fa-regular fa-trash-can me-1"></i>
                                                {{ 'general.delete'|trans }}
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="p-3 text-muted">
                                    {{ 'holiday.no_holidays'|trans }}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
