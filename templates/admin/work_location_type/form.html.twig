{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
    <div class="tt-page">
        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-3">
            <div>
                <h1 class="h3 mb-1">{{ title }}</h1>
                <p class="text-muted mb-0">{{ 'work_location_type.form_subtitle'|trans }}</p>
            </div>

            <a class="btn btn-sm btn-outline-secondary" href="{{ path('_admin_work_location_type_index') }}">
                <i class="fa-solid fa-arrow-left me-1"></i>
                {{ 'general.back'|trans }}
            </a>
        </div>

        <section class="card shadow-sm">
            <div class="card-body">
                {{ form_start(form, { attr: { class: 'row g-3' } }) }}

                <div class="col-12 col-md-4">
                    {{ form_row(form.name) }}
                </div>

                <div class="col-12 col-md-4">
                    {{ form_row(form.keyName) }}
                </div>

                <div class="col-12 col-md-4">
                    {{ form_row(form.icon) }}
                    {% if form.vars.data.icon %}
                        <div class="mt-1 text-muted small">
                            {{ 'general.preview'|trans }}: <i class="{{ form.vars.data.icon }}"></i>
                        </div>
                    {% endif %}
                </div>

                <div class="col-12">
                    <div class="border rounded-3 p-3">
                        <div class="row g-2">
                            <div class="col-12 col-md-6">
                                <div class="form-check">
                                    {{ form_widget(form.isActive, { attr: { class: 'form-check-input' } }) }}
                                    {{ form_label(form.isActive, null, { label_attr: { class: 'form-check-label' } }) }}
                                </div>
                                {{ form_errors(form.isActive) }}
                            </div>

                            <div class="col-12 col-md-6">
                                <div class="form-check">
                                    {{ form_widget(form.isDefault, { attr: { class: 'form-check-input' } }) }}
                                    {{ form_label(form.isDefault, null, { label_attr: { class: 'form-check-label' } }) }}
                                </div>
                                {{ form_errors(form.isDefault) }}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 d-flex justify-content-end gap-2 mt-2">
                    <button class="btn btn-primary" type="submit">
                        <i class="fa-regular fa-floppy-disk me-1"></i>
                        {{ 'general.save'|trans }}
                    </button>
                    <a class="btn btn-outline-secondary" href="{{ path('_admin_work_location_type_index') }}">
                        {{ 'general.cancel'|trans }}
                    </a>
                </div>

                {{ form_end(form) }}
            </div>
        </section>
    </div>
{% endblock %}
