{% extends 'base.html.twig' %}

{% block title %}{{ 'admin_absence_type.title'|trans }}{% endblock %}

{% block body %}
    <div class="tt-page">
        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-3">
            <div>
                <h1 class="h3 mb-1">{{ 'admin_absence_type.title'|trans }}</h1>
                <p class="text-muted mb-0">{{ 'admin_absence_type.subtitle'|trans }}</p>
            </div>

            <a class="btn btn-sm btn-primary" href="{{ path('_admin_absence_type_new') }}">
                <i class="fa-solid fa-plus me-1"></i>
                {{ 'admin_absence_type.create_short'|trans }}
            </a>
        </div>

        <section class="card shadow-sm">
            <div class="card-body p-0">
                {% if types is empty %}
                    <div class="p-3 text-muted">{{ 'admin_absence_type.none'|trans }}</div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                            <tr>
                                <th>{{ 'general.name'|trans }}</th>
                                <th>{{ 'general.key'|trans }}</th>
                                <th>{{ 'general.active'|trans }}</th>
                                <th>{{ 'admin_absence_type.approval'|trans }}</th>
                                <th>{{ 'absence.contingent'|trans }}</th>
                                <th>{{ 'admin_quota.over_limit'|trans }}</th>
                                <th>{{ 'admin_absence_type.default_per_year'|trans }}</th>
                                <th class="text-end"></th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for t in types %}
                                <tr>
                                    <td class="fw-semibold">{{ t.name }}</td>
                                    <td><code>{{ t.keyName }}</code></td>
                                    <td>
                                        {% if t.isActive %}
                                            <span class="badge text-bg-success">{{ 'general.yes'|trans }}</span>
                                        {% else %}
                                            <span class="badge text-bg-secondary">{{ 'general.no'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if t.requiresApproval %}
                                            <span class="badge text-bg-warning">{{ 'general.yes'|trans }}</span>
                                        {% else %}
                                            <span class="badge text-bg-secondary">{{ 'general.no'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if t.requiresQuota %}
                                            <span class="badge text-bg-info">{{ 'general.yes'|trans }}</span>
                                        {% else %}
                                            <span class="badge text-bg-secondary">{{ 'general.no'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if t.allowOverLimit %}
                                            <span class="badge text-bg-warning">{{ 'general.allowed'|trans }}</span>
                                        {% else %}
                                            <span class="badge text-bg-secondary">{{ 'general.blocked'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if not t.requiresQuota %}
                                            <span class="text-muted">{{ 'general.none'|trans }}</span>
                                        {% else %}
                                            {% if t.defaultYearlyQuotaDays is null %}
                                                <span class="text-muted">{{ 'general.unlimited'|trans }}</span>
                                            {% else %}
                                                {{ t.defaultYearlyQuotaDays }}
                                            {% endif %}
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-secondary"
                                           href="{{ path('_admin_absence_type_edit', {id: t.id}) }}">
                                            <i class="fa-regular fa-pen-to-square me-1"></i>
                                            {{ 'general.edit'|trans }}
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </section>
    </div>
{% endblock %}
