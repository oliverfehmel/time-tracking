{% extends 'base.html.twig' %}

{% block title %}Abwesenheitstypen{% endblock %}

{% block body %}
    <div class="tt-page">
        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-3">
            <div>
                <h1 class="h3 mb-1">Abwesenheitstypen</h1>
                <p class="text-muted mb-0">Typen verwalten (Aktiv, Genehmigung, Kontingent).</p>
            </div>

            <a class="btn btn-sm btn-primary" href="{{ path('_admin_absence_type_new') }}">
                <i class="fa-solid fa-plus me-1"></i>
                Typ anlegen
            </a>
        </div>

        <section class="card shadow-sm">
            <div class="card-body p-0">
                {% if types is empty %}
                    <div class="p-3 text-muted">Noch keine Typen angelegt.</div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Key</th>
                                <th>Aktiv</th>
                                <th>Genehmigung</th>
                                <th>Kontingent</th>
                                <th>Standard / Jahr</th>
                                <th class="text-end"></th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for t in types %}
                                <tr>
                                    <td class="fw-semibold">{{ t.name }}</td>
                                    <td><code>{{ t.keyName }}</code></td>
                                    <td>
                                        {% if t.isActive %}
                                            <span class="badge text-bg-success">Ja</span>
                                        {% else %}
                                            <span class="badge text-bg-secondary">Nein</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if t.requiresApproval %}
                                            <span class="badge text-bg-warning">Ja</span>
                                        {% else %}
                                            <span class="badge text-bg-secondary">Nein</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if t.requiresQuota %}
                                            <span class="badge text-bg-info">Ja</span>
                                        {% else %}
                                            <span class="badge text-bg-secondary">Nein</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if not t.requiresQuota %}
                                            <span class="text-muted">—</span>
                                        {% else %}
                                            {% if t.defaultYearlyQuotaDays is null %}
                                                <span class="text-muted">unbegrenzt</span>
                                            {% else %}
                                                {{ t.defaultYearlyQuotaDays }}
                                            {% endif %}
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-secondary"
                                           href="{{ path('_admin_absence_type_edit', {id: t.id}) }}">
                                            <i class="fa-regular fa-pen-to-square me-1"></i>
                                            Bearbeiten
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </section>
    </div>
{% endblock %}
