{% extends 'base.html.twig' %}
{% block title %}{{ 'admin_absence.title'|trans }}{% endblock %}

{% block body %}
    <div class="tt-page">
        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-3">
            <div>
                <h1 class="h3 mb-1">{{ 'admin_absence.heading'|trans }}</h1>
                <p class="text-muted mb-0">{{ 'admin_absence.subtitle'|trans }}</p>
            </div>
        </div>

        <section class="card shadow-sm mb-4">
            <div class="card-header bg-white">
                <h2 class="h5 mb-0">{{ 'admin_absence.pending_title'|trans }}</h2>
            </div>
            <div class="card-body p-0">
                {% if pending is empty %}
                    <div class="p-3 text-muted">
                        {{ 'admin_absence.no_pending'|trans }}
                    </div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                            <tr>
                                <th>{{ 'general.user'|trans }}</th>
                                <th>{{ 'general.type'|trans }}</th>
                                <th>{{ 'general.from'|trans }}</th>
                                <th>{{ 'general.to'|trans }}</th>
                                <th>{{ 'general.days'|trans }}</th>
                                <th>{{ 'general.comment'|trans }}</th>
                                <th class="text-end">{{ 'general.action'|trans }}</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for row in pending %}
                                {% set a = row.entity %}

                                <tr>
                                    <td class="fw-semibold">
                                        <i class="fa-regular fa-user me-1 text-muted"></i>
                                        {{ a.requestedBy.name }}
                                    </td>
                                    <td>{{ a.type.name }}</td>
                                    <td>{{ a.startDate|date('d.m.Y') }}</td>
                                    <td>{{ a.endDate|date('d.m.Y') }}</td>
                                    <td>{{ row.days }}</td>
                                    <td class="text-muted">
                                        {{ a.comment ?: 'general.none'|trans }}
                                    </td>
                                    <td class="text-end">
                                        {% if app.user.id != a.requestedBy.id %}
                                            <div class="d-flex flex-column flex-lg-row justify-content-end gap-2">
                                                <form method="post"
                                                      action="{{ path('_admin_absence_approve', {id: a.id}) }}"
                                                      class="m-0">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('approve_absence_' ~ a.id) }}">
                                                    <button class="btn btn-sm btn-success w-100" type="submit">
                                                        <i class="fa-solid fa-check me-1"></i>
                                                        {{ 'admin_absence.approve'|trans }}
                                                    </button>
                                                </form>

                                                <form method="post"
                                                      action="{{ path('_admin_absence_reject', {id: a.id}) }}"
                                                      class="m-0">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('reject_absence_' ~ a.id) }}">
                                                    <div class="input-group input-group-sm">
                                                        <input class="form-control"
                                                               type="text"
                                                               name="reason"
                                                               placeholder="{{ 'admin_absence.reject_reason'|trans }}"
                                                               required>
                                                        <button class="btn btn-outline-danger" type="submit">
                                                            <i class="fa-solid fa-xmark me-1"></i>
                                                            {{ 'admin_absence.reject'|trans }}
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        {% else %}
                                            <span class="text-muted small">{{ 'admin_absence.own_request'|trans }}</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </section>

        <section class="card shadow-sm">
            <div class="card-header bg-white">
                <h2 class="h5 mb-0">{{ 'admin_absence.processed_title'|trans }}</h2>
            </div>
            <div class="card-body p-0">
                {% if processed is empty %}
                    <div class="p-3 text-muted">
                        {{ 'admin_absence.no_processed'|trans }}
                    </div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                            <tr>
                                <th>{{ 'general.user'|trans }}</th>
                                <th>{{ 'general.type'|trans }}</th>
                                <th>{{ 'general.from'|trans }}</th>
                                <th>{{ 'general.to'|trans }}</th>
                                <th>{{ 'general.days'|trans }}</th>
                                <th>{{ 'general.status'|trans }}</th>
                                <th>{{ 'admin_absence.processed_by'|trans }}</th>
                                <th>{{ 'admin_absence.processed_at'|trans }}</th>
                                <th>{{ 'admin_absence.comment_or_reason'|trans }}</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for row in processed %}
                                {% set a = row.entity %}

                                <tr>
                                    <td class="fw-semibold">
                                        <i class="fa-regular fa-user me-1 text-muted"></i>
                                        {{ a.requestedBy.name }}
                                    </td>
                                    <td>{{ a.type.name }}</td>
                                    <td>{{ a.startDate|date('d.m.Y') }}</td>
                                    <td>{{ a.endDate|date('d.m.Y') }}</td>
                                    <td>{{ row.days }}</td>
                                    <td>
                                        {% if a.status == 'approved' %}
                                            <span class="badge text-bg-success">
                                                <i class="fa-solid fa-check me-1"></i>{{ 'general.approved'|trans }}
                                            </span>
                                        {% elseif a.status == 'rejected' %}
                                            <span class="badge text-bg-danger">
                                                <i class="fa-solid fa-xmark me-1"></i>{{ 'general.rejected'|trans }}
                                            </span>
                                        {% else %}
                                            <span class="badge text-bg-secondary">{{ ('general.' ~ a.status)|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {{ a.approvedBy ? a.approvedBy.name : 'general.none'|trans }}
                                    </td>
                                    <td>
                                        {{ a.approvedAt ? a.approvedAt|date('d.m.Y H:i') : 'general.none'|trans }}
                                    </td>
                                    <td class="text-muted">
                                        {{ a.comment ?: 'general.none'|trans }}
                                        {% if a.status == 'rejected' %}
                                            <hr class="mt-5 mb-5">
                                            {{ a.rejectReason ?: 'general.none'|trans }}
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </section>
    </div>
{% endblock %}
