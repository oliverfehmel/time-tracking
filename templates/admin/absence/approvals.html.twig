{% extends 'base.html.twig' %}
{% block title %}Abwesenheiten genehmigen{% endblock %}

{% block body %}
    <div class="tt-page">
        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-3">
            <div>
                <h1 class="h3 mb-1">Genehmigungen</h1>
                <p class="text-muted mb-0">Offene und bereits bearbeitete Abwesenheitsanträge im Überblick.</p>
            </div>
        </div>

        <section class="card shadow-sm mb-4">
            <div class="card-header bg-white">
                <h2 class="h5 mb-0">Offene Genehmigungen</h2>
            </div>
            <div class="card-body p-0">
                {% if pending is empty %}
                    <div class="p-3 text-muted">
                        Keine offenen Genehmigungen.
                    </div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                            <tr>
                                <th>User</th>
                                <th>Typ</th>
                                <th>Von</th>
                                <th>Bis</th>
                                <th>Tage</th>
                                <th>Kommentar</th>
                                <th class="text-end">Aktion</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for row in pending %}
                                {% set a = row.entity %}

                                <tr>
                                    <td class="fw-semibold">
                                        <i class="fa-regular fa-user me-1 text-muted"></i>
                                        {{ a.requestedBy.name }}
                                    </td>
                                    <td>{{ a.type.name }}</td>
                                    <td>{{ a.startDate|date('d.m.Y') }}</td>
                                    <td>{{ a.endDate|date('d.m.Y') }}</td>
                                    <td>{{ row.days }}</td>
                                    <td class="text-muted">
                                        {{ a.comment ?: '—' }}
                                    </td>
                                    <td class="text-end">
                                        {% if app.user.id != a.requestedBy.id %}
                                            <div class="d-flex flex-column flex-lg-row justify-content-end gap-2">
                                                <form method="post"
                                                      action="{{ path('_admin_absence_approve', {id: a.id}) }}"
                                                      class="m-0">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('approve_absence_' ~ a.id) }}">
                                                    <button class="btn btn-sm btn-success w-100" type="submit">
                                                        <i class="fa-solid fa-check me-1"></i>
                                                        Genehmigen
                                                    </button>
                                                </form>

                                                <form method="post"
                                                      action="{{ path('_admin_absence_reject', {id: a.id}) }}"
                                                      class="m-0">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('reject_absence_' ~ a.id) }}">
                                                    <div class="input-group input-group-sm">
                                                        <input class="form-control"
                                                               type="text"
                                                               name="reason"
                                                               placeholder="Ablehnungsgrund"
                                                               required>
                                                        <button class="btn btn-outline-danger" type="submit">
                                                            <i class="fa-solid fa-xmark me-1"></i>
                                                            Ablehnen
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        {% else %}
                                            <span class="text-muted small">Eigener Antrag</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </section>

        <section class="card shadow-sm">
            <div class="card-header bg-white">
                <h2 class="h5 mb-0">Bereits bearbeitete Anträge</h2>
            </div>
            <div class="card-body p-0">
                {% if processed is empty %}
                    <div class="p-3 text-muted">
                        Keine bereits bearbeiteten Anträge vorhanden.
                    </div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                            <tr>
                                <th>User</th>
                                <th>Typ</th>
                                <th>Von</th>
                                <th>Bis</th>
                                <th>Tage</th>
                                <th>Status</th>
                                <th>Bearbeitet von</th>
                                <th>Bearbeitet am</th>
                                <th>Kommentar / Grund</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for row in processed %}
                                {% set a = row.entity %}

                                <tr>
                                    <td class="fw-semibold">
                                        <i class="fa-regular fa-user me-1 text-muted"></i>
                                        {{ a.requestedBy.name }}
                                    </td>
                                    <td>{{ a.type.name }}</td>
                                    <td>{{ a.startDate|date('d.m.Y') }}</td>
                                    <td>{{ a.endDate|date('d.m.Y') }}</td>
                                    <td>{{ row.days }}</td>
                                    <td>
                                        {% if a.status == 'approved' %}
                                            <span class="badge text-bg-success">
                                                <i class="fa-solid fa-check me-1"></i>Genehmigt
                                            </span>
                                        {% elseif a.status == 'rejected' %}
                                            <span class="badge text-bg-danger">
                                                <i class="fa-solid fa-xmark me-1"></i>Abgelehnt
                                            </span>
                                        {% else %}
                                            <span class="badge text-bg-secondary">{{ a.status }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {{ a.approvedBy ? a.approvedBy.name : '—' }}
                                    </td>
                                    <td>
                                        {{ a.approvedAt ? a.approvedAt|date('d.m.Y H:i') : '—' }}
                                    </td>
                                    <td class="text-muted">
                                        {{ a.comment ?: '—' }}
                                        {% if a.status == 'rejected' %}
                                            <hr class="mt-5 mb-5">
                                            {{ a.rejectReason ?: '—' }}
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </section>
    </div>
{% endblock %}
