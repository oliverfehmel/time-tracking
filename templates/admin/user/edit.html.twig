{% extends 'base.html.twig' %}

{% block title %}{{ 'user.edit'|trans }}{% endblock %}

{% block body %}
    <div class="tt-page">
        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-3">
            <div>
                <h1 class="h3 mb-1">{{ 'user.edit'|trans }}</h1>
                <p class="text-muted mb-0">{{ user.email }}</p>
            </div>

            <a class="btn btn-sm btn-outline-secondary" href="{{ path('_admin_users_index') }}">
                <i class="fa-solid fa-arrow-left me-1"></i>
                {{ 'general.back'|trans }}
            </a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                {{ form_start(form, { attr: { class: 'row g-3' } }) }}

                <div class="col-12 col-md-6">
                    {{ form_row(form.name) }}
                </div>

                <div class="col-12 col-md-6">
                    {{ form_row(form.email) }}
                </div>

                <div class="col-12 col-md-6">
                    {{ form_row(form.dailyWorkMinutes) }}
                </div>

                <div class="col-12 col-md-6">
                    {{ form_row(form.roles) }}
                </div>

                <div class="col-12">
                    {{ form_row(form.plainPassword) }}
                </div>

                <div class="col-12 d-flex justify-content-end gap-2 mt-2">
                    <button class="btn btn-primary" type="submit">
                        <i class="fa-regular fa-floppy-disk me-1"></i>
                        {{ 'general.save'|trans }}
                    </button>
                    <a class="btn btn-outline-secondary" href="{{ path('_admin_users_index') }}">
                        {{ 'general.cancel'|trans }}
                    </a>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
