{% extends 'base.html.twig' %}

{% block title %}{{ 'user.title'|trans }}{% endblock %}

{% block body %}
    <div class="tt-page">
        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-3">
            <div>
                <h1 class="h3 mb-1">{{ 'user.title'|trans }}</h1>
                <p class="text-muted mb-0">{{ 'user.subtitle'|trans }}</p>
            </div>

            <a class="btn btn-sm btn-primary" href="{{ path('_admin_users_new') }}">
                <i class="fa-solid fa-plus me-1"></i>
                {{ 'user.new'|trans }}
            </a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                        <tr>
                            <th>{{ 'general.name'|trans }}</th>
                            <th>{{ 'user.daily_target'|trans }}</th>
                            <th>{{ 'general.email'|trans }}</th>
                            <th>{{ 'user.roles.title'|trans }}</th>
                            <th class="text-end">{{ 'general.actions'|trans }}</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for u in users %}
                            <tr>
                                <td class="fw-semibold">{{ u.name }}</td>
                                <td>{{ (u.dailyWorkMinutes / 60)|number_format(2, ',', '.') }} h</td>
                                <td>{{ u.email }}</td>
                                <td>
                                    <div class="d-flex flex-wrap gap-1">
                                        {% for r in u.roles %}
                                            <span class="badge text-bg-secondary">{{ r }}</span>
                                        {% endfor %}
                                    </div>
                                </td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2 justify-content-end">
                                        <a class="btn btn-sm btn-outline-secondary" href="{{ path('_home', {'_switch_user': u.email}) }}">
                                            <i class="fa-solid fa-user"></i>
                                            Impersonate
                                        </a>

                                        <a class="btn btn-sm btn-outline-secondary" href="{{ path('_admin_users_edit', {id: u.id}) }}">
                                            <i class="fa-regular fa-pen-to-square me-1"></i>
                                            {{ 'general.edit'|trans }}
                                        </a>

                                        <form method="post" action="{{ path('_admin_users_delete', {id: u.id}) }}"
                                              class="m-0 d-inline" onsubmit="return confirm('{{ 'user.confirm_delete'|trans|e('js') }}');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ u.id) }}">
                                            <button class="btn btn-sm btn-outline-danger" type="submit">
                                                <i class="fa-regular fa-trash-can me-1"></i>
                                                {{ 'general.delete'|trans }}
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="p-3 text-muted">
                                    {{ 'user.none'|trans }}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
