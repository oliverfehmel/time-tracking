{% extends 'base.html.twig' %}

{% block title %}{{ 'admin_time.title'|trans }}{% endblock %}

{% block body %}
    <div class="tt-page">
        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-3">
            <div>
                <h1 class="h3 mb-1">{{ 'admin_time.title'|trans }}</h1>
                <p class="text-muted mb-0">{{ 'admin_time.subtitle'|trans }}</p>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-0">
                {% if users is empty %}
                    <div class="p-3 text-muted">{{ 'admin_time.no_users'|trans }}</div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                            <tr>
                                <th>{{ 'general.name'|trans }}</th>
                                <th>{{ 'general.email'|trans }}</th>
                                <th class="text-end">{{ 'general.action'|trans }}</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% set currentYear = "now"|date("Y") %}
                            {% for u in users %}
                                <tr>
                                    <td class="fw-semibold">{{ u.name }}</td>
                                    <td>{{ u.email }}</td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-primary"
                                           href="{{ path('_admin_time_user_year', {id: u.id, year: currentYear}) }}">
                                            <i class="fa-solid fa-arrow-right me-1"></i>
                                            {{ 'general.open'|trans }}
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
